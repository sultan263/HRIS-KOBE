<div class="modal fade" id="formKlaimGigiModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fa-solid fa-tooth me-2"></i> Form Klaim Gigi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <form id="mainFormKlaimGigi" onsubmit="processSubmitKlaimGigi(event)">
                    <div class="row mb-3 bg-light p-3 rounded border">
                        <div class="col-md-8">
                            <label class="form-label fw-bold">Masukkan NRPP Karyawan</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="gigi-nrpp" required placeholder="Contoh: KBE-1001">
                                <button type="button" class="btn btn-dark" onclick="cekDataKaryawanGigi()">Cek Data</button>
                            </div>
                        </div>
                    </div>

                    <div id="area-data-gigi" style="display: none;">
                        <div class="row g-3 mb-4">
                            <div class="col-md-4"><label class="small text-muted">Nama Karyawan</label><input type="text" id="gigi-nama" class="form-control bg-light" readonly></div>
                            <div class="col-md-4"><label class="small text-muted">Departement</label><input type="text" id="gigi-dept" class="form-control bg-light" readonly></div>
                            <div class="col-md-4"><label class="small text-muted">Golongan</label><input type="text" id="gigi-golongan" class="form-control bg-primary text-white fw-bold" readonly></div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-12">
                                <label class="form-label fw-bold">Nama Pasien (Karyawan / Keluarga)</label>
                                <input type="text" id="gigi-pasien" class="form-control border-primary" placeholder="Contoh: Ahmad (Karyawan) atau Siti (Istri)" required>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-success">Sisa Plafon Gigi</label>
                                <input type="text" id="gigi-sisa-text" class="form-control fw-bold text-success" readonly>
                                <input type="hidden" id="gigi-sisa-value">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Tanggal Kwitansi</label>
                                <input type="date" id="gigi-tanggal" class="form-control" required>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label">Nominal Kwitansi</label>
                                <input type="number" id="gigi-kwitansi" class="form-control" required onkeyup="hitungPlafonDisetujuiGigi()">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Nominal Disetujui</label>
                                <input type="number" id="gigi-disetujui" class="form-control bg-light" readonly>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Keterangan Medis</label>
                            <textarea id="gigi-keterangan" class="form-control" rows="2" required placeholder="Contoh: Cabut Gigi Geraham"></textarea>
                        </div>
                        
                        <div class="text-end">
                            <button type="submit" class="btn btn-primary px-4">Submit Klaim Gigi</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
